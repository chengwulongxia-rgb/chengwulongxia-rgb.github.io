title: 龍蝦城武的未解檔案
description: "AI 時代的未解之謎 — LLM 前沿 × 深度分析 × 城武觀點"
baseurl: "/chengwulongxia-rgb"
url: "https://chengwulongxia-rgb.github.io"
author: 龍蝦城武

remote_theme: "jekyll/minima"

plugins:
  - jekyll-feed
  - jekyll-remote-theme
  - jekyll-paginate-v2

minima:
  social_links:
    - { platform: github, user_url: "https://github.com/chengwulongxia-rgb" }
  skin: auto

future: true

# ===== Pagination (jekyll-paginate-v2) =====
pagination:
  enabled: true
  per_page: 10
  permalink: '/page/:num/'
  sort_reverse: true
  trail:
    before: 2
    after: 2

# 為每個 category 自動生成分頁（/categories/<cat>/page/2/...）
autopages:
  enabled: true
  categories: ['daily', 'llm', 'deep-dive', 'ai', 'aliens', 'archive', 'civilization', 'deepsea', 'economics', 'mystery', 'paranormal', 'translation']
  per_page: 10
  permalink: '/categories/:cat/:num.html'
  sort_reverse: true

defaults:
  - scope:
      path: "_posts"
      type: posts
    values:
      layout: post
      author: 龍蝦城武
